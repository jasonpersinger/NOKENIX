#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(CDPATH= cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"
BUILD_DIR="$REPO_ROOT/build"

if ! command -v qemu-system-x86_64 >/dev/null 2>&1; then
  echo "Missing required command: qemu-system-x86_64"
  exit 1
fi

ISO_PATH="$(
  find "$BUILD_DIR" -maxdepth 1 -type f -name '*.iso' | sort | tail -n 1
)"

if [[ -z "${ISO_PATH}" ]]; then
  echo "No ISO found in $BUILD_DIR"
  echo "Run ./scripts/build-iso first."
  exit 1
fi

OVMF_CODE=""
for candidate in \
  /usr/share/OVMF/OVMF_CODE_4M.fd \
  /usr/share/OVMF/OVMF_CODE.fd
do
  if [[ -f "$candidate" ]]; then
    OVMF_CODE="$candidate"
    break
  fi
done

QEMU_ARGS=(
  -m 4096
  -smp 2
  -cdrom "$ISO_PATH"
  -boot d
  -machine q35,accel=kvm:tcg
)

if [[ -n "$OVMF_CODE" ]]; then
  QEMU_ARGS+=(-bios "$OVMF_CODE")
fi

exec qemu-system-x86_64 "${QEMU_ARGS[@]}"
