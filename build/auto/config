#!/bin/sh
set -eu

lb config noauto \
  --architecture amd64 \
  --archive-areas "main" \
  --backports false \
  --binary-image iso-hybrid \
  --bootappend-live "boot=live components quiet splash console=tty0 console=ttyS0,115200 username=nokenix hostname=nokenix" \
  --bootloaders "grub-efi" \
  --debian-installer none \
  --distribution trixie \
  --firmware-binary false \
  --firmware-chroot false \
  --iso-application "NOKENIX Live" \
  --iso-publisher "NOKENIX Project" \
  --iso-volume "NOKENIX" \
  --memtest none \
  "${@}"
